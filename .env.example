# WordBreak backend config. Copy to .env and fill in. NEVER commit real secrets.

PORT=8080

# Referee signer — controls who gets paid. Use a KMS/secrets manager in production.
# Omit REFEREE_PRIVATE_KEY to run the game without settlement signing.
REFEREE_PRIVATE_KEY=
POOLS_CONTRACT=
CHAIN_ID=42220            # 42220 = Celo mainnet, 11142220 = Celo Sepolia

# Read-only RPC used to verify on-chain pool entry (hasEntered) before scoring/paying.
# REQUIRED for paid dailies. Without it, paid submissions are refused (solo still works).
#   Celo Sepolia: https://forno.celo-sepolia.celo-testnet.org
#   Celo mainnet: https://forno.celo.org
CHAIN_RPC_URL=

# Protects /api/admin/* (settlement signing + opening a daily). Omit to disable admin routes.
ADMIN_TOKEN=

SOLO_RACK_SIZE=6
DAILY_RACK_SIZE=6
